# Copy to .env.production locally if you build by hand, OR set the same keys in
# Netlify / GitHub Actions / etc. (Vite only reads VITE_* at build time.)

# Required when the UI is on GitHub Pages / Netlify and the API is elsewhere (e.g. Render):
# VITE_API_BASE_URL=https://your-service.onrender.com/api

# Only if the site is served under a subpath (GitHub Project Pages: user.github.io/REPO-NAME/):
# VITE_BASE_PATH=/REPO-NAME/
